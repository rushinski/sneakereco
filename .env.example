# SneakerEco Environment Contract
# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# Domains and URLs
BASE_DOMAIN=sneakereco.test
API_BASE_URL=https://api.sneakereco.test
PLATFORM_URL=https://sneakereco.test
PLATFORM_DASHBOARD_URL=https://dashboard.sneakereco.test
STATIC_ALLOWED_ORIGINS=https://sneakereco.test,https://dashboard.sneakereco.test
# Database
DATABASE_URL=postgresql://sneakereco_app:app_password@localhost:5432/sneakereco_dev
DATABASE_SYSTEM_URL=postgresql://sneakereco_system:system_password@localhost:5432/sneakereco_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
# Cache and Queue
VALKEY_URL=redis://localhost:6379
QUEUE_PREFIX=sneakereco
# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Shared Admin Cognito
COGNITO_ADMIN_USER_POOL_ID=us-east-1_i8hjAOUQz
COGNITO_PLATFORM_ADMIN_CLIENT_ID=19e00lmbh1tmoj0msr2esc9vp2
COGNITO_TENANT_ADMIN_CLIENT_ID=qm82ifi1ta6aupo9ipjbq9p8f
# Session and Auth
ACCESS_TOKEN_TTL_SECONDS=1800
ADMIN_REFRESH_TOKEN_TTL_SECONDS=86400
CUSTOMER_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_CHALLENGE_SESSION_TTL_SECONDS=600
CSRF_SECRET=
SESSION_SIGNING_SECRET=
# Email
