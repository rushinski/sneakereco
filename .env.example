# ==============================================================================
# SneakerEco API — Environment Variables
# ==============================================================================
#
# All variables are validated at startup via Zod (apps/api/src/config/env.schema.ts).
# The app will refuse to start if a required variable is missing or invalid.
#
# Managed via Doppler:
#   dev        → doppler run --config dev
#   staging    → doppler run --config staging
#   production → doppler run --config production
#
# ==============================================================================


# ==============================================================================
# APPLICATION
# ==============================================================================

NODE_ENV=development
PORT=3000


# ==============================================================================
# DATABASE
# ==============================================================================

# App role — subject to Row Level Security. Used for all user-facing requests.
DATABASE_URL=postgresql://sneakereco_app:app_password@localhost:5432/sneakereco_dev

# System role — bypasses RLS. Used for migrations, background jobs, cross-tenant ops.
DATABASE_SYSTEM_URL=postgresql://sneakereco_system:system_password@localhost:5432/sneakereco_dev

DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10


# ==============================================================================
# VALKEY (Redis-compatible cache + queue)
# ==============================================================================

# Dev:  local Docker valkey
# Prod: DigitalOcean Managed Valkey (rediss:// for TLS)
VALKEY_URL=redis://localhost:6379


# ==============================================================================
# AWS
# ==============================================================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ==============================================================================
# COGNITO
# ==============================================================================

COGNITO_USER_POOL_ID=
# Customer client: 60-min tokens, no MFA required
COGNITO_CUSTOMER_CLIENT_ID=
# Admin client: 30-min tokens, MFA required
COGNITO_ADMIN_CLIENT_ID=


# ==============================================================================
# EMAIL
# ==============================================================================

# smtp → Mailpit (local dev, catches all outbound on port 1025, UI at http://localhost:8025)
# ses  → AWS SES (staging/production)
MAIL_TRANSPORT=smtp

PLATFORM_FROM_EMAIL=noreply@sneakereco.com
PLATFORM_FROM_NAME=SneakerEco
PLATFORM_ADMIN_EMAIL=


# ==============================================================================
# PLATFORM
# ==============================================================================

# Public URL of the platform site. Used for CORS allowlist and building invite links.
# Dev:  http://localhost:3002
# Prod: https://sneakereco.com
PLATFORM_URL=http://localhost:3002

# Platform admin dashboard (dashboard.sneakereco.com).
# Dev:  http://localhost:3002 (middleware rewrites /dashboard/* locally)
# Prod: https://dashboard.sneakereco.com
PLATFORM_DASHBOARD_URL=http://localhost:3002

# Optional www variant added to the CORS allowlist.
# Prod: https://www.sneakereco.com
# PLATFORM_WWW_URL=


# ==============================================================================
# FUTURE — not yet implemented, will be added as modules are built
# ==============================================================================

# --- Object Storage (Cloudflare R2) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# --- Cloudflare API (custom domain management) ---
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# --- Tenant Secrets (AWS SSM Parameter Store) ---
# SSM_PREFIX=/sneakereco/development
# SSM_CACHE_TTL=3600

# --- Payments (PayRilla) ---
# PAYRILLA_API_URL=
# PAYRILLA_TOKENIZATION_URL=
# PAYRILLA_SOURCE_KEY=
# PAYRILLA_PIN=
# PAYRILLA_TOKENIZATION_KEY=

# --- Fraud Detection (NoFraud) ---
# NOFRAUD_API_KEY=
# NOFRAUD_CUSTOMER_CODE=

# --- Tax (ZipTax) ---
# ZIPTAX_API_KEY=

# --- Shipping (Shippo) ---
# SHIPPO_API_TOKEN=
# SHIPPO_WEBHOOK_SECRET=

# --- Address Validation (HERE Maps) ---
# HERE_MAPS_API_KEY=




# ============================================================
# SneakerEco API Configuration
# Copy to .env.local for development
# Production values managed via Doppler
# ============================================================

# --- Application ---
NODE_ENV=
PORT=
LOG_LEVEL=

# --- Database ---
DATABASE_URL=
DATABASE_SYSTEM_URL=
DATABASE_POOL_MIN=
DATABASE_POOL_MAX=

# --- Valkey ---
VALKEY_URL=

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_REGION=
AWS_SECRET_ACCESS_KEY=

# --- AWS Cognito ---
COGNITO_ADMIN_CLIENT_ID=
COGNITO_CUSTOMER_CLIENT_ID=
COGNITO_USER_POOL_ID=

# --- Email ---
MAIL_TRANSPORT=
PLATFORM_ADMIN_EMAIL=
PLATFORM_FROM_EMAIL=
PLATFORM_FROM_NAME=

# --- URLs ---
NEXT_PUBLIC_API_URL=
PLATFORM_URL=
PLATFORM_DASHBOARD_URL=
WEB_URL=

# --- CSRF ---
CSRF_SECRET=
