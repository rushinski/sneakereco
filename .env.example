# ==============================================================================
# SneakerEco Environment Variables
# ==============================================================================
#
# This file documents EVERY environment variable used across the platform.
# The same variable names are used in dev, staging, and production.
# Only the VALUES change per environment.
#
# MANAGEMENT:
#   Development  → Copy this file to .env.local, fill in values
#   Staging      → Managed via Doppler (project: sneakereco, config: staging)
#   Production   → Managed via Doppler (project: sneakereco, config: production)
#
# RULE: If a variable exists here, it must exist in Doppler for staging + prod.
#       No variable should exist in Doppler that isn't documented here.
#
# ==============================================================================


# ==============================================================================
# APPLICATION
# ==============================================================================

# Environment identifier. Controls logging level, error detail, CORS behavior.
# Values: development | staging | production
NODE_ENV=development

# API server port. Nginx/Traefik proxies to this in staging/prod.
PORT=3000

# Public-facing URLs. Used for building links in emails, redirects, CORS origins.
# Dev:     http://localhost:3000, http://localhost:3001
# Staging: https://api-staging.sneakereco.com, https://staging.sneakereco.com
# Prod:    https://api.sneakereco.com, https://sneakereco.com
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
PLATFORM_URL=http://localhost:3002

# Logging level. Use debug in dev, info in staging/prod.
# Values: debug | info | warn | error
LOG_LEVEL=debug


# ==============================================================================
# DATABASE (PostgreSQL 18)
# ==============================================================================

# App role connection — subject to Row Level Security.
# All API requests use this connection. RLS policies filter by tenant automatically.
# Dev:  local Docker postgres
# Staging/Prod: DigitalOcean Managed PostgreSQL connection string
DATABASE_URL=postgresql://sneakereco_app:app_password@localhost:5432/sneakereco_dev

# System role connection — bypasses RLS.
# Used by: migrations, background jobs, cross-tenant operations, webhook handlers.
# NEVER used for user-facing API requests.
DATABASE_SYSTEM_URL=postgresql://sneakereco_system:system_password@localhost:5432/sneakereco_dev

# Connection pool limits. Tune based on droplet size.
# Dev: low values fine. Prod: match to managed DB connection limit.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Statement timeout to prevent runaway queries (milliseconds).
# 30 seconds is generous. Most queries should complete in <500ms.
DATABASE_STATEMENT_TIMEOUT=30000


# ==============================================================================
# CACHE / QUEUE (Valkey 8, Redis-compatible)
# ==============================================================================

# Valkey connection. Used for: caching, BullMQ job queues, rate limiting, sessions.
# Dev:  local Docker valkey
# Staging/Prod: DigitalOcean Managed Valkey connection string (rediss:// for TLS)
VALKEY_URL=redis://localhost:6379

# Optional password. Not needed for local Docker, required for managed Valkey.
VALKEY_PASSWORD=


# ==============================================================================
# OBJECT STORAGE (S3-compatible: MinIO locally, Cloudflare R2 in prod)
# ==============================================================================

# S3-compatible endpoint.
# Dev:  MinIO on Docker
# Prod: Cloudflare R2 endpoint (https://<account-id>.r2.cloudflarestorage.com)
STORAGE_ENDPOINT=http://localhost:9000

# S3-compatible credentials.
# Dev:  MinIO default creds
# Prod: R2 API token credentials (created in Cloudflare dashboard)
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin

# Bucket name. One bucket for all tenants, separated by folder prefixes.
# Dev:  sneakereco-dev
# Staging: sneakereco-staging
# Prod: sneakereco-production
STORAGE_BUCKET=sneakereco-dev

# Public URL for serving stored files (images, documents).
# Dev:  MinIO direct URL
# Staging/Prod: Cloudflare CDN URL pointing to R2 bucket
STORAGE_PUBLIC_URL=http://localhost:9000/sneakereco-dev

# Cloudflare R2 region. Only needed for R2, not MinIO.
# R2 is region-less but the SDK needs a value. Use "auto".
STORAGE_REGION=auto

# Force path style for S3 SDK. Required for MinIO, not needed for R2.
# Dev:  true (MinIO uses path-style: http://localhost:9000/bucket/key)
# Prod: false (R2 uses virtual-hosted-style)
STORAGE_FORCE_PATH_STYLE=true


# ==============================================================================
# AUTHENTICATION (AWS Cognito)
# ==============================================================================

# Cognito User Pool ID. One pool shared across all tenants.
# Dev:  your dev user pool (create a separate one for dev/staging)
# Prod: production user pool
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# App client IDs. Two clients in the same pool with different token expiry/MFA settings.
# Customer client: 60-min tokens, no MFA required
# Admin client:    30-min tokens, MFA required
COGNITO_CUSTOMER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ADMIN_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS region where Cognito is deployed
COGNITO_REGION=us-east-1


# ==============================================================================
# AWS GENERAL
# ==============================================================================

# AWS credentials used for: Cognito API calls, SES, SSM Parameter Store.
# Dev:  IAM user with limited permissions for dev resources
# Prod: IAM user or instance role with prod permissions
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY


# ==============================================================================
# EMAIL (AWS SES)
# ==============================================================================

# Default sender identity. Used as fallback when tenant has no custom email config.
# Must be a verified identity in SES.
SES_FROM_EMAIL=noreply@sneakereco.com
SES_FROM_NAME=SneakerEco

# Platform support email. Shown in emails as "need help? contact us".
PLATFORM_SUPPORT_EMAIL=support@sneakereco.com

# SES region. Can differ from main AWS_REGION if SES is set up in a specific region.
SES_REGION=us-east-1


# ==============================================================================
# TENANT SECRETS (AWS SSM Parameter Store)
# ==============================================================================

# Base path prefix for per-tenant secrets in SSM.
# Actual secrets stored at: {prefix}/payrilla/{tenant_id}/source_key, etc.
# Dev:     /sneakereco/development
# Staging: /sneakereco/staging
# Prod:    /sneakereco/production
SSM_PREFIX=/sneakereco/development

# How long to cache SSM secrets in memory (seconds).
# Avoids hitting SSM on every request. 1 hour = 3600.
SSM_CACHE_TTL=3600


# ==============================================================================
# PAYMENT (PayRilla)
# ==============================================================================

# PayRilla API base URL.
# Dev/Staging: sandbox
# Prod:        production
PAYRILLA_API_URL=https://api.sandbox.payrillagateway.com/api/v2

# Hosted tokenization script URL (loaded by frontend for card input iframes).
# Dev/Staging: sandbox tokenization
# Prod:        production tokenization
PAYRILLA_TOKENIZATION_URL=https://tokenization.sandbox.payrillagateway.com/tokenization/v0.3

# Fallback credentials for single-tenant local development.
# In production, per-tenant credentials are fetched from SSM Parameter Store.
# These are ONLY used when SSM lookup returns nothing (local dev convenience).
PAYRILLA_SOURCE_KEY=
PAYRILLA_PIN=
PAYRILLA_TOKENIZATION_KEY=


# ==============================================================================
# FRAUD DETECTION (NoFraud)
# ==============================================================================

# NoFraud API key for transaction screening.
# Per-tenant in the future, but currently one account for all tenants.
NOFRAUD_API_KEY=

# NoFraud customer code for the frontend JS snippet (device fingerprinting).
NOFRAUD_CUSTOMER_CODE=


# ==============================================================================
# TAX (ZipTax)
# ==============================================================================

# ZipTax API key for sales tax rate lookups.
# Free tier: 100 requests/month. Rates cached in Valkey for 30 days.
ZIPTAX_API_KEY=


# ==============================================================================
# SHIPPING (Shippo)
# ==============================================================================

# Fallback Shippo credentials for single-tenant local development.
# In production, per-tenant credentials are fetched from SSM Parameter Store.
SHIPPO_API_TOKEN=
SHIPPO_WEBHOOK_SECRET=


# ==============================================================================
# ADDRESS VALIDATION (HERE Maps)
# ==============================================================================

# HERE Maps API key for address autocomplete and validation.
HERE_MAPS_API_KEY=


# ==============================================================================
# CLOUDFLARE
# ==============================================================================

# Cloudflare API token. Used for: DNS record management (custom domain setup),
# cache purging, and Workers KV operations.
CLOUDFLARE_API_TOKEN=

# Zone ID for sneakereco.com. Used for managing subdomains.
CLOUDFLARE_ZONE_ID=


# ==============================================================================
# OBSERVABILITY
# ==============================================================================

# Sentry DSN for error tracking and frontend performance monitoring.
# Dev:  can be blank (errors just print to console)
# Staging/Prod: Sentry project DSN
SENTRY_DSN=

# Sentry environment label. Shown in Sentry dashboard to filter by environment.
SENTRY_ENVIRONMENT=development

# Sentry trace sample rate (0.0 to 1.0).
# Dev:  1.0 (trace everything)
# Staging: 0.5
# Prod: 0.1 to 0.2 (sample 10-20% to stay in free tier)
SENTRY_TRACES_SAMPLE_RATE=1.0

# Grafana Cloud credentials for shipping logs and metrics.
# Dev:  leave blank (logs go to console only)
# Staging/Prod: Grafana Cloud Loki/Mimir push URLs and API keys
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_API_KEY=
GRAFANA_MIMIR_URL=
GRAFANA_MIMIR_USER=
GRAFANA_MIMIR_API_KEY=


# ==============================================================================
# ANALYTICS
# ==============================================================================

# Cloudflare Web Analytics beacon token.
# Used to inject the JS snippet into tenant storefronts.
# Get from Cloudflare dashboard > Web Analytics > Add a site.
CLOUDFLARE_ANALYTICS_TOKEN=


# ==============================================================================
# PLATFORM ADMIN
# ==============================================================================

# Email address of the platform owner (you).
# Used for: receiving tenant signup requests, system alerts, error notifications.
PLATFORM_ADMIN_EMAIL=jrushinski@sneakereco.com


# ==============================================================================
# SECRETS MANAGEMENT (Doppler)
# ==============================================================================

# Doppler token. Only needed in CI/CD and on the droplets.
# NOT used in local dev (you use .env.local instead).
# Set as a GitHub Actions secret, not in this file.
# DOPPLER_TOKEN=
