# Caddy reverse proxy for local HTTPS development.
#
# Prerequisites:
#   1. mkcert installed and CA trusted (mkcert -install)
#   2. Certs generated — see docs/local-dev-setup.md
#   3. Wildcard DNS resolving *.sneakereco.test → 127.0.0.1
#      (dnsmasq on macOS/Linux, Acrylic DNS Proxy on Windows)
#
# Usage: docker compose --profile https up -d caddy

{
  local_certs
}

# API
api.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3000
}

# Platform admin dashboard
dashboard.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3002
}

# Platform site (marketing + tenant onboarding)
sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3002
}

# All tenant subdomains (*.sneakereco.test) — storefronts and tenant admin
*.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}

# Simulated tenant custom domain (cross-site to api.sneakereco.test)
heatkings.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}

admin.heatkings.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}
