# Caddy reverse proxy for local HTTPS development.
#
# Prerequisites:
#   1. mkcert installed and CA trusted (mkcert -install)
#   2. Certs generated — see docs/local-dev-setup.md
#   3. *.sneakereco.test entries in /etc/hosts (or C:\Windows\System32\drivers\etc\hosts)
#
# Usage: started automatically via docker compose up caddy
# Caddy forwards HTTPS → HTTP to the app servers running on localhost.

{
  local_certs
}

api.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3000
}

web.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}

admin.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}

platform.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3002
}

heatkings.sneakereco.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}

heatkings.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}

admin.heatkings.test {
  tls /etc/caddy/certs/sneakereco.test.pem /etc/caddy/certs/sneakereco.test-key.pem
  reverse_proxy host.docker.internal:3001
}
