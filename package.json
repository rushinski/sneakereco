{
  "name": "sneakereco",
  "private": true,
  "scripts": {
    "dev": "doppler run -- turbo dev",
    "build": "doppler run -- turbo build",
    "lint": "doppler run -- turbo lint",
    "typecheck": "doppler run -- turbo typecheck",
    "test:unit": "doppler run -- turbo test:unit",
    "test:integration": "doppler run -- turbo test:integration",
    "clean": "turbo clean",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "infra:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "infra:reset": "docker compose -f docker/docker-compose.yml down -v"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.33.0"
}